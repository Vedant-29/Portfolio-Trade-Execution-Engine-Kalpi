# ---------------------------------------------------------------------------
# Kalpi Builder Execution Engine — environment configuration
# Copy to `.env` and fill in your own broker developer-app credentials.
# ---------------------------------------------------------------------------

# App
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Fernet key for encrypting broker access tokens at rest.
# A pre-generated key is included below so the app runs immediately
# after `cp .env.example .env` — no manual setup step needed. Replace
# with a fresh key for any real deployment:  `make fernet-key`
FERNET_KEY=82Oj5_n3Ce7w9Mq5mIQcOkzaIwNTBXz0N9U6olz1zG0=

# Public base URL of this service — used to construct broker OAuth redirect URIs.
# When running under docker-compose locally, http://localhost:8000 is fine.
PUBLIC_BASE_URL=http://localhost:8000

# Where to redirect the browser after a successful OAuth callback.
# - Dev (uvicorn + vite separately):  http://localhost:5173
# - Prod/Docker (FastAPI serves the built UI):  http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# SQLite path for session store (broker access tokens, encrypted).
SESSION_DB_PATH=./data/sessions.sqlite

# ---------------------------------------------------------------------------
# Broker developer-app credentials (one-time setup per broker, per developer).
# Leave blank for brokers you have not yet registered a developer app with.
# The service loads only the brokers whose credentials are present.
# ---------------------------------------------------------------------------

# Zerodha (Kite Connect) — https://developers.kite.trade/
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Upstox — https://upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# AngelOne (SmartAPI) — https://smartapi.angelbroking.com/
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_MPIN=
ANGELONE_TOTP_SECRET=

# Fyers — https://myapi.fyers.in/dashboard
FYERS_API_KEY=
FYERS_API_SECRET=

# Groww — https://groww.in/trade-api/docs
GROWW_API_KEY=
GROWW_API_SECRET=

# Paytm Money — https://developer.paytmmoney.com/
PAYTM_API_KEY=
PAYTM_API_SECRET=
