class {{BROKER_CLASSNAME}}Adapter(BrokerAdapter):
    name = "{{BROKER_NAME}}"
    display_name = "{{BROKER_DISPLAY_NAME}}"
    auth_kind = "credentials_form"

    def __init__(self, api_key: str | None = None) -> None:
        settings = get_settings()
        self._api_key = api_key or settings.{{BROKER_NAME}}_api_key
        if not self._api_key:
            raise AuthError(
                "{{BROKER_DISPLAY_NAME}} adapter requires {{BROKER_NAME_UPPER}}_API_KEY",
                broker="{{BROKER_NAME}}",
            )

    def credential_fields(self) -> list[FieldSpec]:
        """Describes the inputs the UI must render for this broker's
        login form. AngelOne uses (client_id, pin, totp) as a precedent;
        adjust for this broker's requirements."""
        return [
            FieldSpec(name="client_id", label="Client ID", type="text"),
            FieldSpec(name="pin", label="PIN", type="password"),
            FieldSpec(
                name="totp",
                label="6-digit TOTP",
                type="text",
                pattern="[0-9]{6}",
                max_length=6,
                hint="From your authenticator app",
            ),
        ]

    def authenticate_with_credentials(self, **fields: str) -> BrokerSession:
        """POST the user's credentials to the broker's login endpoint."""
        client_id = fields.get("client_id")
        pin = fields.get("pin")
        totp = fields.get("totp")
        if not (client_id and pin and totp):
            raise AuthError(
                "client_id, pin, and totp are required",
