    def authorization_header(self, session: BrokerSession) -> dict[str, str]:
        return {
            "Authorization": session.token_header_format.format(
                access_token=session.access_token
            ),
            "Content-Type": "application/json",
            "Accept": "application/json",
        }

    def place_order(self, session: BrokerSession, req: OrderRequest) -> OrderResult:
        """Place a single order via the broker's SDK.

        If the broker's SDK does not expose an AMO parameter (as with
        Groww today), raise AmoNotSupportedError when req.amo is True
        rather than silently submitting a regular order.
        """
        if req.amo:
            # Delete this block if the broker DOES support AMO and
