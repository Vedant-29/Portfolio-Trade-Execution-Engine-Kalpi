    auth_kind = "api_key_only"

    def __init__(
        self,
        api_key: str | None = None,
        api_secret: str | None = None,
    ) -> None:
        settings = get_settings()
        self._api_key = api_key or settings.{{BROKER_NAME}}_api_key
        self._api_secret = api_secret or settings.{{BROKER_NAME}}_api_secret
        if not (self._api_key and self._api_secret):
            raise AuthError(
                "{{BROKER_DISPLAY_NAME}} adapter requires "
                "{{BROKER_NAME_UPPER}}_API_KEY and {{BROKER_NAME_UPPER}}_API_SECRET",
                broker="{{BROKER_NAME}}",
